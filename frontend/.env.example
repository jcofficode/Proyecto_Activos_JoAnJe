# ─────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE API — JoAnJe Coders
# Cambia esta URL según la ruta de tu servidor local (XAMPP/WAMP/etc.)
# ─────────────────────────────────────────────────────────────────

# Ejemplo XAMPP Windows:  http://localhost/landing_jc/backend/controller/UsuarioControlador_jc.php
# Ejemplo WAMP:           http://localhost:8080/landing_jc/backend/controller/UsuarioControlador_jc.php
VITE_API_URL=http://localhost:tu_puerto/api/v1

# ── Pusher (WebSockets en tiempo real) ─────────────────────────────
# Usa las mismas credenciales que pusiste en backend/.env
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=mt1
