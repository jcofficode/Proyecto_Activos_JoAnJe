Options -Indexes
DirectoryIndex crear.php
RewriteEngine On

# Todo lo que no sea archivo/carpeta real → index.php (API REST)
# Excepto crear.php que es el index del directorio
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Evitar que Apache elimine el token JWT en entornos virtualizados (Railway)
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
CGIPassAuth On
