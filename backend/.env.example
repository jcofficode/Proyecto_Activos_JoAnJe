# ================================================
# .env.example - JoAnJe Coders API
# Copia este archivo como .env y completa los valores.
# NUNCA subas el .env al repositorio.
# ================================================

APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_NAME=gestion_activos_jja
DB_USER=root
DB_PASS=

JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_MUY_SEGURO_DE_256_BITS
JWT_EXPIRA_HORAS=2

# En local: http://localhost:5173 | En Railway: tu dominio del frontend
CORS_ORIGIN=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_gmail
SMTP_SECURE=ssl
MAIL_FROM=tu_correo@gmail.com
MAIL_NAME="JoAnJe Coders"

# Ruta al directorio de uploads (relativa al backend/ o absoluta)
UPLOADS_RUTA=../frontend/uploads
